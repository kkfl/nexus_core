# ─── Nexus Core Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ── Postgres ────────────────────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_pass
POSTGRES_DB=nexus_core
DATABASE_URL=postgresql+asyncpg://nexus:nexus_pass@nexus-postgres:5432/nexus_core

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://nexus-redis:6379/0

# ── Object Storage (MinIO / S3) ────────────────────────────────────────
STORAGE_BACKEND_TYPE=s3
STORAGE_S3_ENDPOINT=http://nexus-minio:9000
STORAGE_S3_ACCESS_KEY=admin
STORAGE_S3_SECRET_KEY=minio_pass
STORAGE_S3_BUCKET=nexus-artifacts
STORAGE_S3_REGION=us-east-1

# ── JWT / Auth ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Vault Encryption (REQUIRED — never commit real key) ────────────────
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
NEXUS_MASTER_KEY=CHANGE_ME_base64_encoded_32_bytes

# ── General ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8000
LOG_LEVEL=INFO

# ── Agent Registry ─────────────────────────────────────────────────────
NEXUS_REGISTRY_AGENT_KEY=nexus-registry-key
AGENT_REGISTRY_KEYS={"nexus": "nexus-registry-key", "admin": "admin-registry-key"}

# ── Portal Build ────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api

# ── Server Agent (Proxmox) ─────────────────────────────────────────────
PROXMOX_BASE_URL=https://your-proxmox-host:8006
PROXMOX_NODE=pve
PROXMOX_VERIFY_SSL=false

# ── Backups ─────────────────────────────────────────────────────────────
BACKUP_HOST_DIR=./backups
