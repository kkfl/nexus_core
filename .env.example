# PostgreSQL Configuration
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_pass
POSTGRES_DB=nexus_core
DATABASE_URL=postgresql+asyncpg://nexus:nexus_pass@localhost:5432/nexus_core

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Storage Backend (S3/MinIO)
STORAGE_BACKEND_TYPE=s3
STORAGE_S3_ENDPOINT=http://localhost:9000
STORAGE_S3_ACCESS_KEY=admin
STORAGE_S3_SECRET_KEY=minio_pass
STORAGE_S3_BUCKET=nexus-artifacts
STORAGE_S3_REGION=us-east-1

# Application Security
SECRET_KEY=change_this_to_a_random_secure_string_for_jwts
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours
NEXUS_MASTER_KEY=Lq/rV+W5s7/V+8S3c5jGZ8s/8i8e6yGZ8s/8i8e6yGY= # 32-byte base64 encoded string

# API Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
