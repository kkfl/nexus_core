{
    "name": "Monitoring Checks Workflow",
    "description": "Periodically synchronizes deployments from the registry and runs active health checks.",
    "trigger": {
        "type": "schedule",
        "cron": "*/2 * * * *"
    },
    "steps": [
        {
            "step_id": "sync_targets",
            "agent_name": "monitoring-agent",
            "action": "POST /v1/targets/sync-from-registry",
            "input": {},
            "timeout_seconds": 15,
            "retry_policy": {
                "max_attempts": 2,
                "backoff_ms": 500
            }
        },
        {
            "step_id": "run_checks",
            "agent_name": "monitoring-agent",
            "action": "POST /v1/check/run",
            "input": {},
            "timeout_seconds": 30,
            "retry_policy": {
                "max_attempts": 1,
                "backoff_ms": 0
            },
            "depends_on": [
                "sync_targets"
            ]
        }
    ]
}