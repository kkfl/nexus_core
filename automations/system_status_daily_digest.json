{
    "name": "System Status Daily Digest",
    "description": "Compiles and sends a daily human-friendly Markdown digest of the platform monitoring state.",
    "tenant_id": "nexus",
    "env": "prod",
    "schedule_cron": "0 8 * * *",
    "enabled": true,
    "notify_on_failure": true,
    "notify_on_success": false,
    "max_concurrent_runs": 1,
    "workflow_spec": {
        "steps": [
            {
                "step_id": "dispatch_digest",
                "agent_name": "monitoring-agent",
                "action": "POST /v1/status/dispatch-digest",
                "input": {},
                "timeout_seconds": 15,
                "retry_policy": {
                    "max_attempts": 2,
                    "backoff_ms": 2000
                }
            }
        ]
    }
}