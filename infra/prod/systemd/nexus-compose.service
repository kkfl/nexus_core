[Unit]
Description=Nexus Core Docker Compose Production
Requires=docker.service
After=docker.service network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/nexus
ExecStart=/usr/bin/docker compose -f infra/prod/docker-compose.prod.yml up -d
ExecStop=/usr/bin/docker compose -f infra/prod/docker-compose.prod.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
